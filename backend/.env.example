PORT=3000
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Option 1: Path to your downloaded service account JSON file (recommended for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase/serviceAccountKey.json

# Option 2: Individual credentials (recommended for hosting / CI/CD)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
